# ===========================================
# MediMind AI — Environment Variables
# Copy this file to .env.local and fill in your values
# ===========================================

# --- Supabase ---
# Found in Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — server-side only, NEVER expose to client. Used for admin
# operations like seeding the global dataset and bypassing RLS for system tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Gemini ---
GEMINI_API_KEY=your-gemini-api-key

# --- App ---
# Used for OAuth redirect URLs and absolute links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google OAuth (configured via Supabase Auth providers, not used directly here) ---
# Set these in Supabase Dashboard > Authentication > Providers > Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
